{
  "mcpServers": {
    "filesystem": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    },
    "weather": {
      "enabled": false,
      "type": "sse",
      "url": "http://localhost:9001/mcp/sse",
      "description": "Weather query service",
      "tools": {
        "get_weather": {
          "card_title": "Weather Info",
          "icon": "cloud-sun",
          "template_path": "/templates/weather/get_weather.html"
        }
      }
    }
  },
  "skills": {}
}